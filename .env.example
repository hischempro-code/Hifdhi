# Hifdhi — Variables d'environnement (template)
# Copie ce fichier vers .env et remplis les valeurs si besoin.
# cp .env.example .env

# Quran.com API v4 — Base URL (API publique, pas de clé requise)
VITE_QURAN_API_BASE=https://api.quran.com/api/v4

# EveryAyah.com — Base URL pour les fichiers audio par verset
VITE_EVERYAYAH_BASE=https://everyayah.com/data

# Google Fonts — URL d'import pour Amiri + Outfit
VITE_GOOGLE_FONTS_URL=https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Outfit:wght@300;400;500;600;700&display=swap
